// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// 开发环境使用 SQLite，生产环境使用 PostgreSQL
// 通过 DATABASE_URL 环境变量控制
// SQLite: DATABASE_URL="file:./dev.db"
// PostgreSQL: DATABASE_URL="postgresql://user:password@localhost:5432/echoenglish"
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User model
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String?
  googleId      String?   @unique
  avatarUrl     String?
  isOnline      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastSeenAt    DateTime?

  messages      Message[]
  settings      UserSetting?
  notifications Notification[]
  
  // Friend relationships
  sentFriendRequests     FriendRequest[] @relation("senderRequests")
  receivedFriendRequests FriendRequest[] @relation("receiverRequests")
  friendships1   Friendship[] @relation("user1")
  friendships2   Friendship[] @relation("user2")
  
  // Group memberships
  groupMemberships GroupMember[]
  
  // Conversation states
  conversationStates UserConversationState[]

  @@index([email])
  @@index([googleId])
}

// User settings model
model UserSetting {
  id              String   @id @default(cuid())
  userId          String   @unique
  language        String   @default("en")
  theme           String   @default("light")
  notifications   Boolean  @default(true)
  emailNotif      Boolean  @default(true)
  pushNotif       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

// Group model - 群聊信息
model Group {
  id          String   @id @default(cuid())
  name        String
  avatarUrl   String?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     GroupMember[]

  @@index([ownerId])
}

// Group member model - 群成员
model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  role      String   @default("member")  // 'owner' | 'admin' | 'member'
  joinedAt  DateTime @default(now())

  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

// Conversation model - 仅用于群聊的共享信息
model Conversation {
  id              String   @id  // group_{groupId}
  groupId         String   // 关联的群 ID
  name            String?  // 群名称 (冗余，便于查询)
  avatarUrl       String?  // 群头像 (冗余)
  latestSeq       Int?
  latestSummary   String?
  latestSenderId  String?
  latestTimestamp DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([latestTimestamp])
}

// UserConversationState model - 用户维度的会话状态（单聊 + 群聊）
model UserConversationState {
  id             String   @id @default(cuid())
  userId         String
  conversationId String   // 单聊：direct_userId1_userId2, 群聊：group_cuid
  type           String   // 'direct' | 'group'
  targetId       String   // 单聊：对方 userId, 群聊：groupId

  lastReadSeq    Int?
  unreadCount    Int      @default(0)
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@index([userId])
  @@index([conversationId])
}

// ContactSyncCursor model - 联系人同步游标（用于增量同步）
model ContactSyncCursor {
  id        String   @id @default(cuid())
  userId    String   @unique
  friendCursor   BigInt   @default(0)  // 好友同步游标（时间戳或自增 ID）
  groupCursor    BigInt   @default(0)  // 群聊同步游标
  requestCursor  BigInt   @default(0)  // 好友请求同步游标
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Message model
model Message {
  id             String   @id @default(cuid())
  msgId          String   @unique // Frontend-generated message ID, for deduplication
  seq            Int      @default(0) // Server-generated sequence number, strictly incremental within conversation
  conversationId String?  // Conversation ID: direct_userId1_userId2 or group_{groupId}
  senderId       String
  text           String
  type           String   @default("text") // text, image, file
  status         String   @default("sent") // sending, sent, delivered, read
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sender         User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([conversationId, seq])
  @@index([conversationId, seq])
  @@index([msgId])
}

// Notification model
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // message, friend_request, system
  title     String
  message   String
  data      String?  // JSON 字符串，SQLite 不支持 Json 类型
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// Email Verification model
model EmailVerification {
  id        String   @id @default(cuid())
  email     String   @unique
  code      String
  userId    String
  expiresAt DateTime
  isVerified Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([code])
}

// Friend Request model
model FriendRequest {
  id        String   @id @default(cuid())
  senderId  String
  receiverId String
  message   String?
  status    String   @default("pending") // pending, accepted, rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sender    User     @relation("senderRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver  User     @relation("receiverRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

// Friendship model
model Friendship {
  id        String   @id @default(cuid())
  userId1   String
  userId2   String
  createdAt DateTime @default(now())

  user1     User     @relation("user1", fields: [userId1], references: [id], onDelete: Cascade)
  user2     User     @relation("user2", fields: [userId2], references: [id], onDelete: Cascade)

  @@unique([userId1, userId2])
  @@index([userId1])
  @@index([userId2])
}
