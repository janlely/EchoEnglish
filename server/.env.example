# OpenRouter API 配置
# 将此文件重命名为 .env 并填写您的实际 API 密钥

# OpenRouter API 密钥 - 必需
OPENROUTER_API_KEY=

# OpenRouter API 基础 URL - 可选，默认为 https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# 使用的模型 - 可选，默认为 openai/gpt-4o-mini
OPENROUTER_MODEL=openai/gpt-4o-mini

# 示例：如果您使用不同的模型
# OPENROUTER_MODEL=anthropic/claude-3-haiku

# 示例：如果您使用 OpenAI 的模型
# OPENROUTER_MODEL=openai/gpt-3.5-turbo